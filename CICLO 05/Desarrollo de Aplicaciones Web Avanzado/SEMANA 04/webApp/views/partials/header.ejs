<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>
    <%= title %> | Empresa
  </title>

  <!-- Bootstrap 5 CDN -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
    integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">

  <!-- CSS propio -->
  <link rel="stylesheet" href="/css/style.css" />
</head>

<body>

  <!-- Navbar -->
  <nav class="navbar navbar-expand-lg navbar-light site-navbar sticky-top">
    <div class="container">
      <a class="navbar-brand brand-mark" href="/">Empresa</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item"><a class="nav-link <%= currentPath === '/' ? 'active' : '' %>" href="/">Inicio</a></li>
          <li class="nav-item"><a class="nav-link <%= currentPath === '/nosotros' ? 'active' : '' %>" href="/nosotros">Nosotros</a></li>
          <li class="nav-item"><a class="nav-link <%= currentPath === '/servicios' ? 'active' : '' %>" href="/servicios">Servicios</a></li>
          <li class="nav-item"><a class="nav-link <%= currentPath === '/contactenos' ? 'active' : '' %>" href="/contactenos">Contáctenos</a></li>
        </ul>
      </div>
    </div>
  </nav>

  <!-- Contenido principal -->
  <main class="container my-5 site-main">